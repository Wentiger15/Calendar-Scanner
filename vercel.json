{
  "buildCommand": "npx expo export --platform web --output-dir dist && mv dist public",
  "outputDirectory": "public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!_expo|assets|favicon.ico).*)",
      "destination": "/index.html"
    }
  ]
}
